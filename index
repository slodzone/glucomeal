<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GlucoMeal — Planer dla Diabetyków T1</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg:        #f7f4ef;
      --surface:   #ffffff;
      --border:    #e8e2d9;
      --text:      #1a1714;
      --muted:     #7a6f66;
      --accent:    #c0533a;
      --accent-lt: #f5ebe7;
      --green:     #3a7c5a;
      --green-lt:  #e6f2ec;
      --radius:    14px;
      --shadow:    0 2px 16px rgba(0,0,0,0.07);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      font-size: 15px;
      line-height: 1.6;
    }

    /* ── LAYOUT ── */
    .app { display: none; }
    .screen { display: none; }
    .screen.active { display: block; }

    /* ── AUTH PAGE ── */
    #auth-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .auth-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 44px 40px;
      width: 100%;
      max-width: 420px;
      box-shadow: var(--shadow);
    }

    .brand {
      text-align: center;
      margin-bottom: 32px;
    }

    .brand-icon {
      width: 52px;
      height: 52px;
      background: var(--accent);
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      margin-bottom: 12px;
    }

    .brand h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 26px;
      color: var(--text);
      letter-spacing: -0.3px;
    }

    .brand p {
      color: var(--muted);
      font-size: 13px;
      margin-top: 4px;
    }

    .auth-tabs {
      display: flex;
      background: var(--bg);
      border-radius: 10px;
      padding: 3px;
      margin-bottom: 28px;
    }

    .auth-tab {
      flex: 1;
      padding: 9px;
      border: none;
      background: transparent;
      border-radius: 8px;
      font-family: inherit;
      font-size: 14px;
      font-weight: 500;
      color: var(--muted);
      cursor: pointer;
      transition: all .2s;
    }

    .auth-tab.active {
      background: var(--surface);
      color: var(--text);
      box-shadow: 0 1px 6px rgba(0,0,0,0.1);
    }

    .field { margin-bottom: 16px; }

    .field label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.4px;
    }

    .field input {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-family: inherit;
      font-size: 15px;
      color: var(--text);
      background: var(--bg);
      transition: border-color .2s;
      outline: none;
    }

    .field input:focus { border-color: var(--accent); background: var(--surface); }

    .btn {
      width: 100%;
      padding: 13px;
      border: none;
      border-radius: 10px;
      font-family: inherit;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: all .2s;
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
    }

    .btn-primary:hover { background: #a84530; }
    .btn-primary:disabled { opacity: .5; cursor: not-allowed; }

    .btn-secondary {
      background: var(--bg);
      color: var(--text);
      border: 1.5px solid var(--border);
    }

    .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

    .msg {
      padding: 11px 14px;
      border-radius: 9px;
      font-size: 13.5px;
      margin-bottom: 16px;
      display: none;
    }

    .msg.error { background: #fdf0ed; color: var(--accent); border: 1px solid #f5cec6; display: block; }
    .msg.success { background: var(--green-lt); color: var(--green); border: 1px solid #b8deca; display: block; }

    /* ── MAIN APP ── */
    .app {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 16px 40px;
    }

    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 0 8px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 28px;
    }

    .header-brand {
      font-family: 'DM Serif Display', serif;
      font-size: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .header-brand span {
      background: var(--accent);
      color: #fff;
      width: 30px;
      height: 30px;
      border-radius: 8px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
    }

    nav {
      display: flex;
      gap: 4px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 3px;
      margin-bottom: 28px;
    }

    .nav-btn {
      flex: 1;
      padding: 9px 8px;
      border: none;
      background: transparent;
      border-radius: 7px;
      font-family: inherit;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      cursor: pointer;
      transition: all .2s;
      white-space: nowrap;
    }

    .nav-btn.active {
      background: var(--surface);
      color: var(--text);
      box-shadow: 0 1px 5px rgba(0,0,0,0.09);
    }

    .logout-btn {
      background: none;
      border: none;
      color: var(--muted);
      font-family: inherit;
      font-size: 13px;
      cursor: pointer;
      padding: 6px 10px;
      border-radius: 7px;
      transition: all .2s;
    }

    .logout-btn:hover { color: var(--accent); background: var(--accent-lt); }

    /* ── CARDS ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      margin-bottom: 20px;
      box-shadow: var(--shadow);
    }

    .card-title {
      font-family: 'DM Serif Display', serif;
      font-size: 19px;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .card-title .icon {
      font-size: 20px;
    }

    .card-desc {
      color: var(--muted);
      font-size: 13.5px;
      margin-bottom: 22px;
    }

    /* ── PROFILE GRID ── */
    .profile-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    @media (max-width: 480px) {
      .profile-grid { grid-template-columns: 1fr; }
      .auth-card { padding: 32px 24px; }
    }

    /* ── INLINE FIELD ── */
    .inline-field { display: flex; flex-direction: column; gap: 5px; }

    .inline-field label {
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.4px;
    }

    .inline-field input, .inline-field select {
      padding: 10px 12px;
      border: 1.5px solid var(--border);
      border-radius: 9px;
      font-family: inherit;
      font-size: 15px;
      color: var(--text);
      background: var(--bg);
      outline: none;
      transition: border-color .2s;
    }

    .inline-field input:focus,
    .inline-field select:focus { border-color: var(--accent); background: #fff; }

    .inline-field .unit {
      font-size: 12px;
      color: var(--muted);
    }

    .save-row {
      margin-top: 20px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .save-row .btn { width: auto; padding: 11px 24px; }

    .save-status {
      font-size: 13px;
      color: var(--green);
      opacity: 0;
      transition: opacity .3s;
    }

    .save-status.visible { opacity: 1; }

    /* ── STATS ROW ── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 24px;
    }

    .stat-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px;
      text-align: center;
    }

    .stat-box .stat-val {
      font-family: 'DM Serif Display', serif;
      font-size: 24px;
      color: var(--text);
    }

    .stat-box .stat-lbl {
      font-size: 11px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-top: 2px;
    }

    .stat-box .stat-empty {
      font-size: 20px;
      color: var(--border);
    }

    /* ── CALCULATOR ── */
    .calc-input-row {
      display: flex;
      gap: 12px;
      align-items: flex-end;
      flex-wrap: wrap;
    }

    .calc-input-row .inline-field { flex: 1; min-width: 120px; }

    .calc-result {
      margin-top: 22px;
      padding: 20px 22px;
      background: var(--accent-lt);
      border: 1.5px solid #e8c4bb;
      border-radius: 12px;
      display: none;
    }

    .calc-result.visible { display: block; }

    .calc-result .result-label {
      font-size: 12px;
      font-weight: 600;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 6px;
    }

    .calc-result .result-dose {
      font-family: 'DM Serif Display', serif;
      font-size: 38px;
      color: var(--accent);
      line-height: 1;
    }

    .calc-result .result-dose span {
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      font-weight: 500;
      color: var(--muted);
      margin-left: 6px;
    }

    .calc-result .result-detail {
      font-size: 13px;
      color: var(--muted);
      margin-top: 10px;
      padding-top: 10px;
      border-top: 1px solid #e8c4bb;
    }

    .disclaimer {
      margin-top: 16px;
      padding: 12px 14px;
      background: #fffbf0;
      border: 1px solid #f0dfa0;
      border-radius: 9px;
      font-size: 12.5px;
      color: #7a6a20;
      line-height: 1.5;
    }

    .disclaimer strong { display: block; margin-bottom: 2px; }

    /* ── INFO TAB ── */
    .info-section { margin-bottom: 24px; }

    .info-section h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 17px;
      margin-bottom: 10px;
      color: var(--text);
    }

    .info-section p {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 10px;
    }

    .info-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13.5px;
      margin-top: 10px;
    }

    .info-table th {
      background: var(--bg);
      padding: 9px 12px;
      text-align: left;
      font-weight: 600;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.4px;
    }

    .info-table td {
      padding: 9px 12px;
      border-bottom: 1px solid var(--border);
      color: var(--text);
    }

    .info-table tr:last-child td { border-bottom: none; }

    .badge {
      display: inline-block;
      padding: 3px 8px;
      border-radius: 5px;
      font-size: 11px;
      font-weight: 600;
    }

    .badge-green { background: var(--green-lt); color: var(--green); }
    .badge-yellow { background: #fffbf0; color: #7a6a20; }
    .badge-red { background: var(--accent-lt); color: var(--accent); }

    /* ── BMI ── */
    .bmi-bar-wrap {
      margin-top: 14px;
    }

    .bmi-bar {
      height: 8px;
      border-radius: 4px;
      background: linear-gradient(to right, #6ab4f5, #5cc97a, #f5c842, #f58a42, #e84e2a);
      position: relative;
      margin-bottom: 6px;
    }

    .bmi-needle {
      position: absolute;
      top: -4px;
      width: 16px;
      height: 16px;
      background: var(--text);
      border: 2px solid white;
      border-radius: 50%;
      transform: translateX(-50%);
      transition: left .5s ease;
    }

    .bmi-labels {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: var(--muted);
    }

    .bmi-value {
      font-family: 'DM Serif Display', serif;
      font-size: 28px;
      color: var(--text);
      margin-top: 10px;
    }

    .bmi-category {
      font-size: 13px;
      font-weight: 600;
      margin-top: 2px;
    }
  </style>
</head>
<body>

<!-- ════════════════════════════════ AUTH ════════════════════════════════ -->
<div id="auth-page">
  <div class="auth-card">
    <div class="brand">
      <div class="brand-icon">🩸</div>
      <h1>GlucoMeal</h1>
      <p>Planer posiłków dla diabetyków T1</p>
    </div>

    <div class="auth-tabs">
      <button class="auth-tab active" onclick="switchTab('login')">Logowanie</button>
      <button class="auth-tab" onclick="switchTab('register')">Rejestracja</button>
    </div>

    <div id="auth-msg" class="msg"></div>

    <!-- LOGIN -->
    <div id="login-form">
      <div class="field">
        <label>E-mail</label>
        <input type="email" id="login-email" placeholder="twoj@email.com" />
      </div>
      <div class="field">
        <label>Hasło</label>
        <input type="password" id="login-pass" placeholder="••••••••" />
      </div>
      <button class="btn btn-primary" onclick="login()" id="login-btn">Zaloguj się</button>
    </div>

    <!-- REGISTER -->
    <div id="register-form" style="display:none">
      <div class="field">
        <label>E-mail</label>
        <input type="email" id="reg-email" placeholder="twoj@email.com" />
      </div>
      <div class="field">
        <label>Hasło (min. 6 znaków)</label>
        <input type="password" id="reg-pass" placeholder="••••••••" />
      </div>
      <button class="btn btn-primary" onclick="register()" id="reg-btn">Utwórz konto</button>
    </div>
  </div>
</div>

<!-- ════════════════════════════════ APP ════════════════════════════════ -->
<div class="app" id="main-app">

  <header>
    <div class="header-brand">
      <span>🩸</span> GlucoMeal
    </div>
    <button class="logout-btn" onclick="logout()">Wyloguj →</button>
  </header>

  <nav>
    <button class="nav-btn active" onclick="showScreen('dashboard')">Pulpit</button>
    <button class="nav-btn" onclick="showScreen('calculator')">Kalkulator</button>
    <button class="nav-btn" onclick="showScreen('profile')">Profil</button>
    <button class="nav-btn" onclick="showScreen('info')">Informacje</button>
  </nav>

  <!-- ── DASHBOARD ── -->
  <div class="screen active" id="screen-dashboard">

    <div class="stats-row">
      <div class="stat-box">
        <div class="stat-val" id="dash-weight">—</div>
        <div class="stat-lbl">Waga (kg)</div>
      </div>
      <div class="stat-box">
        <div class="stat-val" id="dash-a1c">—</div>
        <div class="stat-lbl">HbA1c (%)</div>
      </div>
      <div class="stat-box">
        <div class="stat-val" id="dash-icr">—</div>
        <div class="stat-lbl">ICR (g/j)</div>
      </div>
    </div>

    <div class="card" id="bmi-card" style="display:none">
      <div class="card-title"><span class="icon">📊</span> BMI</div>
      <div class="bmi-value" id="bmi-val">—</div>
      <div class="bmi-category" id="bmi-cat"></div>
      <div class="bmi-bar-wrap">
        <div class="bmi-bar">
          <div class="bmi-needle" id="bmi-needle" style="left:0%"></div>
        </div>
        <div class="bmi-labels">
          <span>Niedowaga</span>
          <span>Norma</span>
          <span>Nadwaga</span>
          <span>Otyłość</span>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-title"><span class="icon">💡</span> Szybki kalkulator</div>
      <div class="card-desc">Ile węglowodanów masz w posiłku?</div>
      <div class="calc-input-row">
        <div class="inline-field">
          <label>Węglowodany <span class="unit">(g)</span></label>
          <input type="number" id="quick-carbs" placeholder="np. 60" min="0" oninput="quickCalc()" />
        </div>
      </div>
      <div class="calc-result" id="quick-result">
        <div class="result-label">Sugerowana dawka</div>
        <div class="result-dose" id="quick-dose">0<span>jednostek</span></div>
        <div class="result-detail" id="quick-detail"></div>
      </div>
      <div class="disclaimer">
        <strong>⚠️ Ważna informacja</strong>
        Aplikacja służy wyłącznie jako pomoc w obliczeniach. Zawsze konsultuj dawkowanie insuliny z lekarzem lub diabetologiem. Nie zastępuje to porady medycznej.
      </div>
    </div>

  </div>

  <!-- ── CALCULATOR ── -->
  <div class="screen" id="screen-calculator">
    <div class="card">
      <div class="card-title"><span class="icon">🧮</span> Kalkulator bolusu</div>
      <div class="card-desc">Wpisz ile węglowodanów zawiera Twój posiłek, a kalkulator obliczy sugerowaną dawkę insuliny na podstawie Twojego ICR.</div>

      <div class="calc-input-row" style="margin-bottom: 14px;">
        <div class="inline-field">
          <label>Węglowodany <span class="unit">(g)</span></label>
          <input type="number" id="calc-carbs" placeholder="np. 60" min="0" oninput="fullCalc()" />
        </div>
        <div class="inline-field">
          <label>Twój ICR <span class="unit">(g węgl./j)</span></label>
          <input type="number" id="calc-icr-override" placeholder="z profilu" min="1" oninput="fullCalc()" />
        </div>
      </div>

      <div class="calc-result" id="full-result">
        <div class="result-label">Sugerowana dawka insuliny</div>
        <div class="result-dose" id="full-dose">0<span>jednostek</span></div>
        <div class="result-detail" id="full-detail"></div>
      </div>

      <div class="disclaimer" style="margin-top: 16px;">
        <strong>⚠️ Ważna informacja</strong>
        Podany wynik to jedynie wynik działania matematycznego (węglowodany ÷ ICR). Na rzeczywistą dawkę insuliny wpływa wiele czynników: aktywność fizyczna, aktualny poziom glikemii, typ posiłku i inne. Zawsze stosuj dawkowanie zalecone przez lekarza.
      </div>
    </div>

    <div class="card">
      <div class="card-title"><span class="icon">📖</span> Jak używać kalkulatora?</div>
      <p style="font-size:14px; color:var(--muted); line-height:1.7;">
        <strong style="color:var(--text);">ICR (Insulin-to-Carb Ratio)</strong> — stosunek węglowodanów do jednostki insuliny. Np. ICR = 10 oznacza, że 1 jednostka insuliny pokrywa 10g węglowodanów.<br><br>
        <strong style="color:var(--text);">Wzór:</strong> Dawka = Węglowodany ÷ ICR<br><br>
        Twoje ICR ustalasz razem z diabetologiem i wpisujesz w zakładce <em>Profil</em>.
      </p>
    </div>
  </div>

  <!-- ── PROFILE ── -->
  <div class="screen" id="screen-profile">
    <div class="card">
      <div class="card-title"><span class="icon">👤</span> Dane osobowe</div>
      <div class="card-desc">Te dane pomagają śledzić postępy i kalkulować dawki.</div>

      <div class="profile-grid">
        <div class="inline-field">
          <label>Waga <span class="unit">(kg)</span></label>
          <input type="number" id="p-weight" placeholder="np. 70" min="20" max="300" step="0.1" />
        </div>
        <div class="inline-field">
          <label>Wzrost <span class="unit">(cm)</span></label>
          <input type="number" id="p-height" placeholder="np. 170" min="100" max="250" />
        </div>
        <div class="inline-field">
          <label>Ostatni HbA1c <span class="unit">(%)</span></label>
          <input type="number" id="p-a1c" placeholder="np. 7.2" min="4" max="15" step="0.1" />
        </div>
        <div class="inline-field">
          <label>ICR — Twój stosunek <span class="unit">(g/j)</span></label>
          <input type="number" id="p-icr" placeholder="np. 10" min="1" max="50" />
        </div>
      </div>

      <div class="save-row">
        <button class="btn btn-primary" onclick="saveProfile()">Zapisz profil</button>
        <div class="save-status" id="save-status">✓ Zapisano</div>
      </div>
    </div>

    <div class="card">
      <div class="card-title"><span class="icon">🔑</span> ICR — co to jest?</div>
      <p style="font-size:14px; color:var(--muted); line-height:1.7;">
        ICR (ang. <em>Insulin-to-Carbohydrate Ratio</em>) to liczba gramów węglowodanów pokrywanych przez jedną jednostkę insuliny. Jest indywidualny i ustalany z diabetologiem — <strong style="color:var(--text);">wpisz tutaj swój ICR zalecony przez lekarza.</strong>
      </p>
    </div>
  </div>

  <!-- ── INFO ── -->
  <div class="screen" id="screen-info">
    <div class="card">
      <div class="card-title"><span class="icon">📚</span> Poziomy HbA1c</div>
      <div class="card-desc">Zalecenia Polskiego Towarzystwa Diabetologicznego (PTD)</div>
      <table class="info-table">
        <thead>
