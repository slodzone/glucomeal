<!-- ════════════════════ SUPABASE + LOGIC ════════════════════ -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>

  // ══════════════════════════════════════════
  //  ⚙️  KONFIGURACJA — wklej swoje dane
  // ══════════════════════════════════════════
  const SUPABASE_URL  = 'https://giqybscwxjawokvupzbk.supabase.co';
  const SUPABASE_ANON = 'yJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdpcXlic2N3eGphd29rdnVwemJrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4ODIzMzcsImV4cCI6MjA5MDQ1ODMzN30.QpT-fM7Vxq0AVrvzR9_zzUYJ7Alad0rkd5CbgWFKurY';
  // ══════════════════════════════════════════

  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON);

  let currentUser = null;
  let userProfile = {};

  // ── INIT ──
  async function init() {
    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      currentUser = session.user;
      showApp();
    } else {
      showAuthPage();
    }
    sb.auth.onAuthStateChange((_event, session) => {
      if (session) { currentUser = session.user; showApp(); }
      else { showAuthPage(); }
    });
  }

  function showAuthPage() {
    document.getElementById('auth-page').style.display = 'flex';
    document.getElementById('main-app').style.display = 'none';
  }

  function showApp() {
    document.getElementById('auth-page').style.display = 'none';
    document.getElementById('main-app').style.display = 'block';
    loadProfile();
  }

  // ── AUTH TABS ──
  function switchTab(tab) {
    document.querySelectorAll('.auth-tab').forEach((b,i) => b.classList.toggle('active', (i===0) === (tab==='login')));
    document.getElementById('login-form').style.display    = tab === 'login'    ? 'block' : 'none';
    document.getElementById('register-form').style.display = tab === 'register' ? 'block' : 'none';
    clearMsg();
  }

  function showMsg(text, type) {
    const el = document.getElementById('auth-msg');
    el.textContent = text;
    el.className = 'msg ' + type;
  }

  function clearMsg() {
    const el = document.getElementById('auth-msg');
    el.className = 'msg';
    el.textContent = '';
  }

  // ── LOGIN ──
  async function login() {
    const email = document.getElementById('login-email').value.trim();
    const pass  = document.getElementById('login-pass').value;
    if (!email || !pass) return showMsg('Wypełnij e-mail i hasło.', 'error');
    const btn = document.getElementById('login-btn');
    btn.disabled = true; btn.textContent = 'Logowanie…';
    const { error } = await sb.auth.signInWithPassword({ email, password: pass });
    btn.disabled = false; btn.textContent = 'Zaloguj się';
    if (error) showMsg('Błąd: ' + error.message, 'error');
  }

  // ── REGISTER ──
  async function register() {
    const email = document.getElementById('reg-email').value.trim();
    const pass  = document.getElementById('reg-pass').value;
    if (!email || !pass) return showMsg('Wypełnij e-mail i hasło.', 'error');
    if (pass.length < 6)  return showMsg('Hasło musi mieć min. 6 znaków.', 'error');
    const btn = document.getElementById('reg-btn');
    btn.disabled = true; btn.textContent = 'Tworzenie konta…';
    const { error } = await sb.auth.signUp({ email, password: pass });
    btn.disabled = false; btn.textContent = 'Utwórz konto';
    if (error) showMsg('Błąd: ' + error.message, 'error');
    else showMsg('Konto utworzone! Sprawdź e-mail w celu potwierdzenia.', 'success');
  }

  // ── LOGOUT ──
  async function logout() {
    await sb.auth.signOut();
  }

  // ── PROFILE ──
  async function loadProfile() {
    if (!currentUser) return;
    const { data } = await sb.from('profiles').select('*').eq('user_id', currentUser.id).single();
    if (data) {
      userProfile = data;
      document.getElementById('p-weight').value = data.weight || '';
      document.getElementById('p-height').value = data.height || '';
      document.getElementById('p-a1c').value    = data.a1c    || '';
      document.getElementById('p-icr').value    = data.icr    || '';
      updateDashboard();
    }
  }

  async function saveProfile() {
    const weight = parseFloat(document.getElementById('p-weight').value) || null;
    const height = parseFloat(document.getElementById('p-height').value) || null;
    const a1c    = parseFloat(document.getElementById('p-a1c').value)    || null;
    const icr    = parseFloat(document.getElementById('p-icr').value)    || null;

    const payload = { user_id: currentUser.id, weight, height, a1c, icr, updated_at: new Date().toISOString() };

    const { error } = await sb.from('profiles').upsert(payload, { onConflict: 'user_id' });
    if (!error) {
      userProfile = payload;
      updateDashboard();
      const s = document.getElementById('save-status');
      s.classList.add('visible');
      setTimeout(() => s.classList.remove('visible'), 2500);
    }
  }

  function updateDashboard() {
    const { weight, height, a1c, icr } = userProfile;
    document.getElementById('dash-weight').textContent = weight ? weight + ' kg' : '—';
    document.getElementById('dash-a1c').textContent    = a1c    ? a1c + '%'     : '—';
    document.getElementById('dash-icr').textContent    = icr    ? icr           : '—';

    if (weight && height) {
      const bmi = weight / ((height / 100) ** 2);
      const bmiRound = Math.round(bmi * 10) / 10;
      document.getElementById('bmi-card').style.display = 'block';
      document.getElementById('bmi-val').textContent = bmiRound;
      const cat = bmi < 18.5 ? 'Niedowaga' : bmi < 25 ? 'Prawidłowa masa ciała' : bmi < 30 ? 'Nadwaga' : 'Otyłość';
      const catClass = bmi < 18.5 ? 'badge-yellow' : bmi < 25 ? 'badge-green' : bmi < 30 ? 'badge-yellow' : 'badge-red';
      document.getElementById('bmi-cat').innerHTML = `<span class="badge ${catClass}">${cat}</span>`;
      // needle: BMI 16=0% 40=100%
      const pct = Math.min(100, Math.max(0, ((bmi - 16) / 24) * 100));
      document.getElementById('bmi-needle').style.left = pct + '%';
    }
  }

  // ── QUICK CALC (dashboard) ──
  function quickCalc() {
    const carbs = parseFloat(document.getElementById('quick-carbs').value);
    const icr   = userProfile.icr;
    const res   = document.getElementById('quick-result');

    if (!carbs || carbs <= 0) { res.classList.remove('visible'); return; }
    if (!icr) {
      res.classList.add('visible');
      document.getElementById('quick-dose').innerHTML = '—<span>ustaw ICR w Profilu</span>';
      document.getElementById('quick-detail').textContent = '';
      return;
    }
    const dose = carbs / icr;
    res.classList.add('visible');
    document.getElementById('quick-dose').innerHTML = `${Math.round(dose * 10) / 10}<span>jednostek</span>`;
    document.getElementById('quick-detail').textContent = `${carbs}g węglowodanów ÷ ICR ${icr} = ${Math.round(dose * 10) / 10} j.`;
  }

  // ── FULL CALC (calculator tab) ──
  function fullCalc() {
    const carbs    = parseFloat(document.getElementById('calc-carbs').value);
    const icrInput = parseFloat(document.getElementById('calc-icr-override').value);
    const icr      = icrInput || userProfile.icr;
    const res      = document.getElementById('full-result');

    if (!carbs || carbs <= 0) { res.classList.remove('visible'); return; }
    if (!icr) {
      res.classList.add('visible');
      document.getElementById('full-dose').innerHTML = '—<span>wpisz ICR powyżej lub w Profilu</span>';
      document.getElementById('full-detail').textContent = '';
      return;
    }
    const dose = carbs / icr;
    res.classList.add('visible');
    document.getElementById('full-dose').innerHTML = `${Math.round(dose * 10) / 10}<span>jednostek</span>`;
    document.getElementById('full-detail').textContent = `${carbs}g węglowodanów ÷ ICR ${icr} = ${Math.round(dose * 10) / 10} jednostek insuliny`;
  }

  // ── NAV ──
  function showScreen(name) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('screen-' + name).classList.add('active');
    event.currentTarget.classList.add('active');
  }

  init();
</script>
</body>
</html>
